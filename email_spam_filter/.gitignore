# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so

# Bytecode
*.pyc
*.pyo
*.pyd

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/
ENV/

# =========================
# Packaging / build
# =========================
build/
dist/
*.egg-info/
.eggs/

# =========================
# Pytest / coverage
# =========================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# =========================
